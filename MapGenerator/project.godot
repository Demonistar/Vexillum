; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the properties have to be formatted correctly or Godot can't parse it.
; It was created by the editor and is meant to be version-controlled.

config_version=5

[application]

config/name="VEXILLUM Map Generator"
config/description="Module 1A — standalone map geometry validator"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")

[autoload]

GameConstants="*res://scripts/GameConstants.gd"
PathGenerator="*res://scripts/PathGenerator.gd"
MapManager="*res://scripts/MapManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/stretch/mode="disabled"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
